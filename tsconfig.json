{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "outDir": "./dist/",
    "noImplicitAny": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "jsx": "react-jsx",
    "allowJs": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}